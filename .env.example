# ─── Telegram Live Chat ────────────────────────────────────────────────────────
# Set these in your Vercel project settings (or any host that supports env vars).
# When both are present the live chat widget is enabled automatically without
# needing to configure anything in the Admin Dashboard.
VITE_TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ─── ImgBB Image Uploads ───────────────────────────────────────────────────────
# Optional: set your ImgBB API key here instead of the Admin Settings page.
VITE_IMGBB_API_KEY=your_imgbb_api_key_here

# ─── GitHub (Server-side — Vercel Serverless Comment API) ─────────────────────
# These are server-side variables for the /api/add-comment serverless function.
# Set them in Vercel Project Settings → Environment Variables.
# Do NOT use the VITE_ prefix — they must stay on the server and never reach the browser.
# Required for any visitor to be able to post comments (no localStorage token needed).
#
#   GITHUB_TOKEN    — Personal Access Token with "repo" (contents read + write) scope
#   GITHUB_USERNAME — GitHub username or organisation that owns the repo
#   GITHUB_REPO     — Repository name (e.g. pcreative)
#   GITHUB_BRANCH   — Branch to commit comments to (defaults to "main" if omitted)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=you2show
GITHUB_REPO=pcreative
GITHUB_BRANCH=main
